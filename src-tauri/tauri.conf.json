{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zhibi-writer",
  "version": "0.3.9",
  "identifier": "com.zhibi.writer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "执笔",
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "minHeight": 720,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "dmg"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "template": "nsis/installer.nsi"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://ghfast.top/github.com/D-ai042/zhibi/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFEMkEwMzU5RjREQTgzOTAKUldTUWc5cjBXUU1xSGFBeFRqNGsrR2VVcHBnUjhTcmc0LzdlUURhanNMZTlBYmJ2Z3RQakh5cUkK"
    }
  }
}
