{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Novel Workbench default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-confirm",
    "dialog:allow-save",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-load",
    "sql:allow-close",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
